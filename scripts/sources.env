# Upstream sources for the xovi ecosystem (aarch64 / reMarkable Paper Pro).
#
# Pinned to known-good releases for reproducibility. To update: bump the TAG and
# the resolver below picks the matching asset. Set RMPP_KIT_LATEST=1 in the
# environment to instead resolve the newest release at install time.
#
# Verified against the GitHub releases API. Asset-naming gotchas, so you don't
# grab the wrong file:
#   • The "xovi" INSTALL bundle is a tarball from the *rm-xovi-extensions* repo
#     (NOT the asivery/xovi loader repo). It already contains the loader
#     (xovi.so), the bootstrap scripts, and qt-resource-rebuilder.
#   • AppLoad is a separate zip from asivery/rm-appload.
#   • xovi-message-broker ships INSIDE the bundle (inactive-extensions/), so we
#     activate it rather than download it.

# --- pinned versions ---
XOVI_BUNDLE_TAG="${XOVI_BUNDLE_TAG:-v19-23052026}"   # asivery/rm-xovi-extensions
APPLOAD_TAG="${APPLOAD_TAG:-v0.5.3}"                  # asivery/rm-appload

# --- resolved URLs ---
# Bundle: loader + scripts + qt-resource-rebuilder + inactive-extensions.
XOVI_BUNDLE_URL="https://github.com/asivery/rm-xovi-extensions/releases/download/${XOVI_BUNDLE_TAG}/xovi-aarch64.tar.gz"
# AppLoad extension zip.
APPLOAD_URL="https://github.com/asivery/rm-appload/releases/download/${APPLOAD_TAG}/appload-aarch64.zip"
# Community-blessed persistence (install-script based; no release asset).
TRIPLETAP_INSTALL_URL="https://raw.githubusercontent.com/rmitchellscott/xovi-tripletap/main/install.sh"

# Resolve the newest release instead of the pins above, if asked.
# Usage inside a script:  resolve_latest OWNER/REPO ASSET_NAME  -> prints URL
resolve_latest() {
    local repo="$1" asset="$2"
    if command -v gh >/dev/null 2>&1; then
        gh api "repos/$repo/releases/latest" \
            --jq ".assets[]|select(.name==\"$asset\").browser_download_url" 2>/dev/null
    else
        curl -fsSL "https://api.github.com/repos/$repo/releases/latest" \
            | grep -o "\"browser_download_url\": *\"[^\"]*$asset\"" \
            | head -n1 | sed 's/.*"\(https[^"]*\)"/\1/'
    fi
}

if [ "${RMPP_KIT_LATEST:-0}" = 1 ]; then
    XOVI_BUNDLE_URL="$(resolve_latest asivery/rm-xovi-extensions xovi-aarch64.tar.gz)"
    APPLOAD_URL="$(resolve_latest asivery/rm-appload appload-aarch64.zip)"
fi
